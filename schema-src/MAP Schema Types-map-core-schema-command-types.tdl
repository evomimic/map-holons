schema MAP Core Schema-v0.0.7 {
  depends_on MAP Dance Schema-v0.0.4
}
abstract holon CommandType {
  header {
    description: "Abstract descriptor type for core MAP command affordances discoverable through descriptor-local command lookup."
    display_name: "Command Type"
    display_plural: "Command Types"
    plural: "CommandTypes"
  }
  relationships {
    (CommandType.HolonType)-[CommandPayloadType]->(HolonType)
  }
}


holon BeginTransaction {
  extends CommandType.HolonType
  header {
    description: "Opens a new transaction for a holon space."
    display_name: "Begin Transaction Command"
    display_plural: "Begin Transaction Commands"
    plural: "BeginTransactionCommands"
  }
}


holon CloneHolon {
  extends CommandType.HolonType
  header {
    description: "Creates a transient clone of the target holon."
    display_name: "Clone Holon Command"
    display_plural: "Clone Holon Commands"
    plural: "CloneHolonCommands"
  }
}


holon Summarize {
  extends CommandType.HolonType
  header {
    description: "Returns a concise string summary of the target holon."
    display_name: "Summarize Command"
    display_plural: "Summarize Commands"
    plural: "SummarizeCommands"
  }
}


holon GetHolonId {
  extends CommandType.HolonType
  header {
    description: "Returns the target holon's saved holon identifier."
