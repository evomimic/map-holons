holon DeleteHolon {
  extends CommandType.HolonType
  header {
    description: "Deletes a holon identified by ID from the active transaction."
    display_name: "Delete Holon Command"
    display_plural: "Delete Holon Commands"
    plural: "DeleteHolonCommands"
  }
}


def relationship AffordsCommand {
  source HolonType
  target CommandType.HolonType
  inverse CommandAffordedBy
  cardinality 0..32767
  deletion_semantic Allow
  header {
    description: "Declares that a HolonType affords a CommandType, making the command discoverable through descriptor-local command affordance lookup."
    display_name: "AffordsCommand Relationship"
    display_plural: "AffordsCommand Relationships"
    plural: "AffordsCommandRelationships"
  }
}


inverse relationship CommandAffordedBy {
  source CommandType.HolonType
  target HolonType
  cardinality 0..32767
  deletion_semantic Allow
  header {
    description: "Inverse of AffordsCommand, relationship from CommandType to HolonType."
    display_name: "CommandAffordedBy Relationship"
    display_plural: "CommandAffordedBy Relationships"
    plural: "CommandAffordedByRelationships"
  }
}


def relationship CommandPayloadType {
  source CommandType.HolonType
  target HolonType
  inverse CommandPayloadTypeFor
  cardinality 0..1
  header {
    description: "Links a CommandType to the holon type carried as its command payload."
    display_name: "CommandPayloadType Relationship"
    display_plural: "CommandPayloadType Relationships"
    plural: "CommandPayloadTypeRelationships"
  }
}


inverse relationship CommandPayloadTypeFor {
  source HolonType
  target CommandType.HolonType
  cardinality 0..32767
  header {
    description: "Inverse of CommandPayloadType, from HolonType to CommandType."
    display_name: "CommandPayloadTypeFor Relationship"
    display_plural: "CommandPayloadTypeFor Relationships"
    plural: "CommandPayloadTypeForRelationships"
  }
}
