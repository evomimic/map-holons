    display_plural: "Get Key Commands"
    plural: "GetKeyCommands"
  }
}


holon GetVersionedKey {
  extends CommandType.HolonType
  header {
    description: "Returns the target holon's versioned key."
    display_name: "Get Versioned Key Command"
    display_plural: "Get Versioned Key Commands"
    plural: "GetVersionedKeyCommands"
  }
}


holon GetPropertyValue {
  extends CommandType.HolonType
  header {
    description: "Returns the value of a named property on the target holon, if present."
    display_name: "Get Property Value Command"
    display_plural: "Get Property Value Commands"
    plural: "GetPropertyValueCommands"
  }
}


holon GetRelatedHolons {
  extends CommandType.HolonType
  header {
    description: "Returns holons related to the target holon through a named relationship."
    display_name: "Get Related Holons Command"
    display_plural: "Get Related Holons Commands"
    plural: "GetRelatedHolonsCommands"
  }
}


