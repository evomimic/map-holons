  source ExecutionBinding.HolonType
  target ExecutionInstance.HolonType
  cardinality 0..1
  header {
    description: "Inverse of ExecutionBindings, from ExecutionBinding to ExecutionInstance."
    display_name: "BindingForExecutionInstance Relationship"
    display_plural: "BindingForExecutionInstance Relationships"
    plural: "BindingForExecutionInstanceRelationships"
  }
}


def relationship BindsQueryVariable {
  source ExecutionBinding.HolonType
  target QueryBinding.HolonType
  inverse ExecutionVariableBinding
  cardinality 1..1
  header {
    description: "Links an ExecutionBinding to the symbolic QueryBinding (variable) it binds."
    display_name: "BindsQueryVariable Relationship"
    display_plural: "BindsQueryVariable Relationships"
    plural: "BindsQueryVariableRelationships"
  }
}


inverse relationship ExecutionVariableBinding {
  source QueryBinding.HolonType
  target ExecutionBinding.HolonType
  cardinality 0..32767
  header {
    description: "Inverse of BindsQueryVariable, from QueryBinding to ExecutionBinding."
    display_name: "ExecutionVariableBinding Relationship"
    display_plural: "ExecutionVariableBinding Relationships"
    plural: "ExecutionVariableBindingRelationships"
  }
}


def relationship BoundCollection {
  source ExecutionBinding.HolonType
  target HolonCollection.HolonType
  inverse CollectionBoundIn
  cardinality 1..1
  header {
    description: "Links an ExecutionBinding to the runtime HolonCollection it binds its variable to."
    display_name: "BoundCollection Relationship"
    display_plural: "BoundCollection Relationships"
    plural: "BoundCollectionRelationships"
  }
}


inverse relationship CollectionBoundIn {
  source HolonCollection.HolonType
  target ExecutionBinding.HolonType
  cardinality 0..32767
  header {
    description: "Inverse of BoundCollection, from HolonCollection to ExecutionBinding."
    display_name: "CollectionBoundIn Relationship"
    display_plural: "CollectionBoundIn Relationships"
    plural: "CollectionBoundInRelationships"
  }
}


relationship ExecutionResult {
  source ExecutionInstance.HolonType
  target HolonCollection.HolonType
  inverse ResultOfExecution
  cardinality 0..1
  header {
    description: "Links an ExecutionInstance to the final HolonCollection result of the run."
    display_name: "ExecutionResult Relationship"
    display_plural: "ExecutionResult Relationships"
    plural: "ExecutionResultRelationships"
  }
}


inverse relationship ResultOfExecution {
  source HolonCollection.HolonType
  target ExecutionInstance.HolonType
  cardinality 0..32767
  header {
    description: "Inverse of ExecutionResult, from HolonCollection to ExecutionInstance."
    display_name: "ResultOfExecution Relationship"
    display_plural: "ResultOfExecution Relationships"
    plural: "ResultOfExecutionRelationships"
  }
}
